# Frontend environment variables — Vite reads these as import.meta.env.VITE_*
#
# For local dev: copy this file to .env.local and fill in real values.
#   cp .env.example .env.local
#
# For production: these are injected by GitHub Actions from GitHub repository Secrets.
# Never commit .env.local or any file with real values.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_WORKER_URL=
